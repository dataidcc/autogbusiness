# Copy file này thành `.env` ở thư mục gốc rồi điền giá trị thật.
# docker compose tự đọc `.env` này để thay ${VAR}.

# --- Postgres ---
# Đổi khác mặc định nếu chạy production (team truy cập từ xa).
POSTGRES_PASSWORD=doi-mat-khau-manh

# --- JWT --- generate: openssl rand -hex 32
JWT_SECRET=__THAY_BANG_64_HEX_NGAU_NHIEN__

# --- Super-admin seed (chỉ dùng lần đầu khi DB rỗng) ---
# Đổi password ngay sau khi login lần đầu (Cài đặt → Đổi mật khẩu).
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=__MAT_KHAU_MANH_MIN_12_KY_TU__

# --- URL công khai team truy cập (dùng cho CORS) ---
# Vd: https://gpt.ten-mien-cua-ban.com
PUBLIC_URL=https://gpt.ten-mien-cua-ban.com

# --- Cloudflare Tunnel token ---
# Lấy ở: Cloudflare Zero Trust → Networks → Tunnels → tạo tunnel → copy token.
# Chỉ cần khi chạy với `--profile remote`.
CF_TUNNEL_TOKEN=__DAN_TUNNEL_TOKEN__
