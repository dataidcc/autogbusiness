# Database
DATABASE_URL=postgresql+psycopg://autogpt:autogpt@localhost:5432/autogpt_dashboard

# JWT — generate: openssl rand -hex 32   (hoặc PowerShell: -join ((48..57)+(97..102) | Get-Random -Count 64 | ForEach-Object {[char]$_}))
JWT_SECRET=__REPLACE_WITH_RANDOM_64_HEX__
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# CORS - frontend origin
FRONTEND_ORIGIN=http://localhost:5173

# Super-admin seed (chỉ dùng lần đầu khi DB rỗng).
# Đổi password ngay sau khi login lần đầu qua /Cài đặt.
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=__REPLACE_WITH_STRONG_PASSWORD_MIN_12_CHARS__

# Extension API key (Chrome Extension dùng header X-API-KEY) — generate: openssl rand -hex 24
# Lưu ý: Tuần 2 sẽ chuyển sang per-workspace API key; biến này chỉ là bootstrap key tạm thời.
EXTENSION_API_KEY=__REPLACE_WITH_RANDOM_48_HEX__
